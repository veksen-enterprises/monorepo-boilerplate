{
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    ".claude/skills/**",
    "skills-lock.json",
    "**/migrations/**",
    "**/drizzle/**",
  ],
  "printWidth": 80,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "experimentalTailwindcss": {
    "attributes": ["class", "className"],
    "functions": ["clsx", "cn", "tailwind-merge"],
  },
  "experimentalSortImports": {
    "customGroups": [
      { "elementNamePattern": ["react", "react-*"], "groupName": "react" },
    ],
    "groups": [
      "builtin",
      "react",
      "external",
      "internal",
      "parent",
      "sibling",
      "index",
    ],
    "internalPattern": ["@repo/", "@/", "~/"],
    "newlinesBetween": false,
    "order": "asc",
    "ignoreCase": true,
  },
}
