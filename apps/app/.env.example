# Copy to .env and adjust. .env is gitignored.
# The Connect RPC backend — Fastify (apps/api-fastify) on 3001, or Go (apps/api-go) on 8080.
VITE_API_URL=http://localhost:3001

# Clerk (https://dashboard.clerk.com) — optional; the app runs without it (public RPCs only).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
