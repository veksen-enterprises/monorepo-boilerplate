# Copy to .env and export before running (the sample reads real env; use direnv or
# `set -a; . ./.env; set +a`). .env is gitignored.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
PORT=8080

# Clerk (https://dashboard.clerk.com) — dev instance secret key.
CLERK_SECRET_KEY=sk_test_...
